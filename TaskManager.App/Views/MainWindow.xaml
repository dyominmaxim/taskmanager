<Window x:Class="TaskManager.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:TaskManager.App.ViewModels"
        xmlns:conv="clr-namespace:TaskManager.App.Converters"
        Title="Менеджер задач"
        Width="960" Height="600"
        MinWidth="640" MinHeight="400"
        WindowStartupLocation="CenterScreen">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <conv:EnumDisplayConverter x:Key="EnumDisplay"/>
    </Window.Resources>

    <DockPanel>

        <!-- Строка состояния -->
        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem Content="{Binding StatusMessage}"/>
        </StatusBar>

        <!-- Тулбар -->
        <ToolBar DockPanel.Dock="Top">
            <Button Content="Новая задача"   Command="{Binding NewTaskCommand}"/>
            <Button Content="Редактировать"  Command="{Binding EditTaskCommand}"/>
            <Button Content="Удалить"        Command="{Binding DeleteTaskCommand}"/>
            <Separator/>
            <Button Content="Сохранить JSON" Command="{Binding SaveCommand}"/>
            <Button Content="Загрузить JSON" Command="{Binding LoadCommand}"/>
        </ToolBar>

        <!-- Панель фильтров -->
        <Grid DockPanel.Dock="Top" Margin="6,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="150"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Text="Статус:" VerticalAlignment="Center" Margin="0,0,6,0"/>
            <ComboBox  Grid.Column="1"
                       ItemsSource="{Binding StatusFilters}"
                       SelectedItem="{Binding FilterStatus}"/>

            <TextBlock Grid.Column="2" Text="Поиск:" VerticalAlignment="Center" Margin="12,0,6,0"/>
            <TextBox   Grid.Column="3"
                       Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"/>
        </Grid>

        <!-- Таблица задач -->
        <DataGrid ItemsSource="{Binding Tasks}"
                  SelectedItem="{Binding SelectedTask}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  MouseDoubleClick="OnRowDoubleClick">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Название"   Binding="{Binding Title}"       Width="2*"/>
                <DataGridTextColumn Header="Описание"   Binding="{Binding Description}" Width="3*"/>
                <DataGridTextColumn Header="Приоритет"  Width="*">
                    <DataGridTextColumn.Binding>
                        <Binding Path="Priority" Converter="{StaticResource EnumDisplay}"/>
                    </DataGridTextColumn.Binding>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Статус"     Width="*">
                    <DataGridTextColumn.Binding>
                        <Binding Path="Status" Converter="{StaticResource EnumDisplay}"/>
                    </DataGridTextColumn.Binding>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Срок"
                                    Binding="{Binding DueDate, StringFormat=dd.MM.yyyy, TargetNullValue=—}"
                                    Width="*"/>
                <DataGridTextColumn Header="Создана"
                                    Binding="{Binding CreatedAt, StringFormat=dd.MM.yyyy}"
                                    Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

    </DockPanel>
</Window>
