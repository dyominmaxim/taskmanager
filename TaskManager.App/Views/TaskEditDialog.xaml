<Window x:Class="TaskManager.App.Views.TaskEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:TaskManager.App.Converters"
        Title="Задача"
        Width="420" Height="340"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">

    <Window.Resources>
        <conv:EnumDisplayConverter x:Key="EnumDisplay"/>
    </Window.Resources>

    <DockPanel Margin="12">

        <!-- Кнопки ОК / Отмена -->
        <StackPanel DockPanel.Dock="Bottom"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,10,0,0">
            <Button Content="ОК"
                    Width="80"
                    IsDefault="True"
                    Click="OnOk"
                    Margin="0,0,8,0"/>
            <Button Content="Отмена"
                    Width="80"
                    IsCancel="True"/>
        </StackPanel>

        <!-- Форма -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="90"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Название -->
            <TextBlock Grid.Row="0" Grid.Column="0"
                       Text="Название:"
                       VerticalAlignment="Center"
                       Margin="0,4"/>
            <TextBox   Grid.Row="0" Grid.Column="1"
                       x:Name="TitleBox"
                       Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}"
                       Margin="0,4"/>

            <!-- Приоритет -->
            <TextBlock Grid.Row="1" Grid.Column="0"
                       Text="Приоритет:"
                       VerticalAlignment="Center"
                       Margin="0,4"/>
            <ComboBox  Grid.Row="1" Grid.Column="1"
                       ItemsSource="{x:Static local:TaskEditDialog.PriorityValues}"
                       SelectedItem="{Binding Priority}"
                       Margin="0,4"
                       xmlns:local="clr-namespace:TaskManager.App.Views">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Converter={StaticResource EnumDisplay}}"/>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>

            <!-- Статус -->
            <TextBlock Grid.Row="2" Grid.Column="0"
                       Text="Статус:"
                       VerticalAlignment="Center"
                       Margin="0,4"/>
            <ComboBox  Grid.Row="2" Grid.Column="1"
                       ItemsSource="{x:Static local:TaskEditDialog.StatusValues}"
                       SelectedItem="{Binding Status}"
                       Margin="0,4"
                       xmlns:local="clr-namespace:TaskManager.App.Views">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Converter={StaticResource EnumDisplay}}"/>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>

            <!-- Срок выполнения -->
            <TextBlock   Grid.Row="3" Grid.Column="0"
                         Text="Срок:"
                         VerticalAlignment="Center"
                         Margin="0,4"/>
            <DatePicker  Grid.Row="3" Grid.Column="1"
                         SelectedDate="{Binding DueDate}"
                         Margin="0,4"/>

            <!-- Описание -->
            <TextBlock Grid.Row="4" Grid.Column="0"
                       Text="Описание:"
                       VerticalAlignment="Top"
                       Margin="0,8,0,0"/>
            <TextBox   Grid.Row="4" Grid.Column="1"
                       Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                       AcceptsReturn="True"
                       TextWrapping="Wrap"
                       VerticalScrollBarVisibility="Auto"
                       Margin="0,4"/>
        </Grid>
    </DockPanel>
</Window>
