<Window x:Class="TaskManager.WPF.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:TaskManager.WPF.ViewModels"
        xmlns:conv="clr-namespace:TaskManager.WPF.Converters"
        Title="Менеджер задач"
        Width="900" Height="600"
        MinWidth="600" MinHeight="400"
        WindowStartupLocation="CenterScreen">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <conv:PriorityToStringConverter x:Key="PriorityConv"/>
        <conv:StatusToStringConverter   x:Key="StatusConv"/>
    </Window.Resources>

    <DockPanel>

        <!-- Панель инструментов -->
        <ToolBar DockPanel.Dock="Top">
            <Button Content="Добавить"     Command="{Binding AddCommand}"    Padding="8,2"/>
            <Button Content="Редактировать" Command="{Binding EditCommand}"   Padding="8,2"/>
            <Button Content="Удалить"      Command="{Binding DeleteCommand}" Padding="8,2"/>
            <Separator/>
            <Button Content="Сохранить"    Command="{Binding SaveCommand}"   Padding="8,2"/>
            <Button Content="Загрузить"    Command="{Binding LoadCommand}"   Padding="8,2"/>
        </ToolBar>

        <!-- Строка состояния -->
        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem Content="{Binding StatusMessage}"/>
        </StatusBar>

        <!-- Фильтры -->
        <Grid DockPanel.Dock="Top" Margin="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="150"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Label Grid.Column="0" Content="Статус:" VerticalAlignment="Center"/>
            <ComboBox Grid.Column="1"
                      ItemsSource="{Binding StatusFilters}"
                      SelectedItem="{Binding SelectedStatusFilter}"
                      Margin="0,0,8,0"/>

            <Label Grid.Column="2" Content="Поиск:" VerticalAlignment="Center"/>
            <TextBox Grid.Column="3"
                     Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                     VerticalContentAlignment="Center"/>
        </Grid>

        <!-- Список задач -->
        <DataGrid ItemsSource="{Binding Tasks}"
                  SelectedItem="{Binding SelectedTask}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column"
                  CanUserReorderColumns="False"
                  Margin="4,0,4,4">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Название"   Binding="{Binding Name}"        Width="*"/>
                <DataGridTextColumn Header="Приоритет"  Width="90"
                                    Binding="{Binding Priority, Converter={StaticResource PriorityConv}}"/>
                <DataGridTextColumn Header="Срок"       Width="100"
                                    Binding="{Binding Deadline, StringFormat=dd.MM.yyyy}"/>
                <DataGridTextColumn Header="Статус"     Width="100"
                                    Binding="{Binding Status, Converter={StaticResource StatusConv}}"/>
                <DataGridTextColumn Header="Описание"   Binding="{Binding Description}" Width="2*"/>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Window>
