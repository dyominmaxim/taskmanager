<Window x:Class="TaskManager.WPF.Views.TaskEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Задача"
        Width="400" Height="320"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="90"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Название -->
        <Label Grid.Row="0" Grid.Column="0" Content="Название:" VerticalAlignment="Center"/>
        <TextBox Grid.Row="0" Grid.Column="1"
                 x:Name="NameBox"
                 Margin="0,4"
                 VerticalContentAlignment="Center"/>

        <!-- Описание -->
        <Label Grid.Row="1" Grid.Column="0" Content="Описание:" VerticalAlignment="Top" Margin="0,6,0,0"/>
        <TextBox Grid.Row="1" Grid.Column="1"
                 x:Name="DescBox"
                 Height="60"
                 Margin="0,4"
                 AcceptsReturn="True"
                 TextWrapping="Wrap"
                 VerticalScrollBarVisibility="Auto"/>

        <!-- Приоритет -->
        <Label Grid.Row="2" Grid.Column="0" Content="Приоритет:" VerticalAlignment="Center"/>
        <ComboBox Grid.Row="2" Grid.Column="1"
                  x:Name="PriorityCombo"
                  Margin="0,4"
                  SelectedIndex="1">
            <ComboBoxItem Content="Низкий"/>
            <ComboBoxItem Content="Средний"/>
            <ComboBoxItem Content="Высокий"/>
        </ComboBox>

        <!-- Срок -->
        <Label Grid.Row="3" Grid.Column="0" Content="Срок:" VerticalAlignment="Center"/>
        <DatePicker Grid.Row="3" Grid.Column="1"
                    x:Name="DeadlinePicker"
                    Margin="0,4"/>

        <!-- Статус -->
        <Label Grid.Row="4" Grid.Column="0" Content="Статус:" VerticalAlignment="Center"/>
        <ComboBox Grid.Row="4" Grid.Column="1"
                  x:Name="StatusCombo"
                  Margin="0,4"
                  SelectedIndex="0">
            <ComboBoxItem Content="Новая"/>
            <ComboBoxItem Content="В процессе"/>
            <ComboBoxItem Content="Завершена"/>
        </ComboBox>

        <!-- Кнопки -->
        <StackPanel Grid.Row="6" Grid.Column="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,8,0,0">
            <Button Content="OK"
                    IsDefault="True"
                    Width="75"
                    Margin="0,0,8,0"
                    Click="OnOk"/>
            <Button Content="Отмена"
                    IsCancel="True"
                    Width="75"
                    Click="OnCancel"/>
        </StackPanel>
    </Grid>
</Window>
